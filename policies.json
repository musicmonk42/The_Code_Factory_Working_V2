# Compliance Controls Configuration
# This file defines the compliance controls for the OmniCore Engine
# Format: YAML with compliance_controls section
# Compatible with NIST 800-53, SOC 2, ISO 27001, and other frameworks

version: 1.0.0
description: Default compliance controls for code generation, testing, and deployment validation

# Compliance controls define the security and governance requirements
compliance_controls:
  # Access Control (AC)
  AC-1:
    name: Access Control Policy and Procedures
    description: Establishes policies and procedures for managing system and information access
    status: enforced
    required: true
  
  AC-2:
    name: Account Management
    description: Manages information system accounts, including establishment, activation, modification, disabling, and removal
    status: enforced
    required: true
  
  AC-3:
    name: Access Enforcement
    description: Enforces approved authorizations for logical and physical access to information and system resources
    status: enforced
    required: true
  
  AC-6:
    name: Least Privilege
    description: Enforces the principle of least privilege, allowing users and processes only the necessary access
    status: enforced
    required: true
  
  # Audit and Accountability (AU)
  AU-2:
    name: Audit Events
    description: Determines, documents, and disseminates audit events requiring logging
    status: enforced
    required: true
  
  AU-6:
    name: Audit Review, Analysis, and Reporting
    description: Reviews and analyzes information system audit records
    status: enforced
    required: true
  
  AU-12:
    name: Audit Generation
    description: Provides audit record generation capability for auditable events
    status: enforced
    required: true
  
  # Configuration Management (CM)
  CM-2:
    name: Baseline Configuration
    description: Establishes and maintains baseline configurations and inventories of information system components
    status: enforced
    required: true
  
  CM-3:
    name: Configuration Change Control
    description: Determines, documents, approves, and implements changes to the system
    status: enforced
    required: true
  
  # Identification and Authentication (IA)
  IA-2:
    name: Identification and Authentication (Organizational Users)
    description: Uniquely identifies and authenticates organizational users
    status: enforced
    required: true
  
  IA-5:
    name: Authenticator Management
    description: Manages information system authenticators
    status: enforced
    required: true
  
  # System and Communications Protection (SC)
  SC-7:
    name: Boundary Protection
    description: Monitors and controls communications at external boundaries and key internal boundaries
    status: enforced
    required: true
  
  SC-8:
    name: Transmission Confidentiality and Integrity
    description: Protects the confidentiality and integrity of transmitted information
    status: enforced
    required: true
  
  SC-13:
    name: Cryptographic Protection
    description: Implements cryptographic mechanisms to protect information
    status: enforced
    required: true
  
  # System and Information Integrity (SI)
  SI-2:
    name: Flaw Remediation
    description: Identifies, reports, and corrects information system flaws
    status: enforced
    required: true
  
  SI-3:
    name: Malicious Code Protection
    description: Implements malicious code protection mechanisms
    status: enforced
    required: true
  
  SI-4:
    name: Information System Monitoring
    description: Monitors the information system to detect attacks and indicators of potential attacks
    status: enforced
    required: true
  
  SI-7:
    name: Software, Firmware, and Information Integrity
    description: Employs integrity verification tools to detect unauthorized changes
    status: enforced
    required: true
  
  # Code Generation Specific Controls
  CG-1:
    name: Code Quality Standards
    description: Ensures generated code meets quality, security, and maintainability standards
    status: enforced
    required: true
  
  CG-2:
    name: Security Scanning
    description: Performs security scanning on generated code and configurations
    status: enforced
    required: true
  
  CG-3:
    name: Test Coverage Requirements
    description: Ensures adequate test coverage for generated code
    status: enforced
    required: true
  
  CG-4:
    name: Documentation Standards
    description: Ensures comprehensive documentation is generated for all code
    status: enforced
    required: true
  
  # Deployment Validation Controls
  DV-1:
    name: Container Security
    description: Validates container security and configuration
    status: enforced
    required: true
  
  DV-2:
    name: Vulnerability Scanning
    description: Performs vulnerability scanning on deployment artifacts
    status: enforced
    required: true
  
  DV-3:
    name: Configuration Compliance
    description: Validates deployment configurations against security baselines
    status: enforced
    required: true
  
  # Data Protection Controls
  DP-1:
    name: Sensitive Data Redaction
    description: Identifies and redacts sensitive data in logs and outputs
    status: enforced
    required: true
  
  DP-2:
    name: Data Encryption
    description: Encrypts sensitive data at rest and in transit
    status: enforced
    required: true
