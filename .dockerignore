# Documentation and audit files
# Explicitly exclude large/generated markdown and the Sphinx build output.
# All other markdown (deploy_templates, generator, server, docs source, etc.)
# is kept so that Sphinx and runtime code that reads markdown templates work.
docs/_build/
patent_doc.md
LICENSE

# Development and CI files
.pre-commit-config.yaml
.ruff.toml
Makefile
run_integration_tests.py
docker-compose.dev.yml
.devcontainer/

# SECURITY: Environment files with secrets
# Exclude ALL .env files to prevent credential leakage
.env
.env.*
*.env
.env.example
.env.local
.env.production
.env.development
.env.test

# Monitoring and health check scripts (not needed in runtime)
monitoring/
health_check.py
