# Sphinx documentation — build output, config, and scaffolding are not needed at runtime.
# docs/_build/ in particular can be very large; exclude it explicitly so a local
# sphinx-build run does not inflate the image.
docs/conf.py
docs/index.rst
docs/_build/
docs/_static/
docs/_templates/
docs/*.rst

# Development and CI files
.pre-commit-config.yaml
.ruff.toml
Makefile
run_integration_tests.py
docker-compose.dev.yml
.devcontainer/

# SECURITY: Environment files with secrets
# Exclude ALL .env files to prevent credential leakage
.env
.env.*
*.env
.env.example
.env.local
.env.production
.env.development
.env.test

# Monitoring and health check scripts (not needed in runtime)
monitoring/
health_check.py
