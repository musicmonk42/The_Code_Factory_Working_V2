# Code Factory Platform Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# CRITICAL: Production Configuration
# =============================================================================
# Set PRODUCTION_MODE=1 to enable production behavior:
# - Fail-fast on missing required API keys
# - Enable audit logging and monitoring
# - Disable test/stub implementations
# - Enable Prometheus metrics
PRODUCTION_MODE=0  # Set to 1 for production

# =============================================================================
# Application Environment
# =============================================================================
# APP_ENV controls environment-specific behavior
# Options: development, production, staging, testing
APP_ENV=development
DEBUG=true

# Testing mode (for CI/CD pipelines)
# When enabled, skips heavy initialization and uses stubs
TESTING=0  # Set to 1 in CI/CD

# =============================================================================
# Feature Flags - Core Infrastructure
# =============================================================================
# Enable/disable optional platform components
# SECURITY: Changed from "auto" to explicit "0" for powerful subsystems
# Only enable features you actually use to reduce attack surface

# Database functionality (PostgreSQL/SQLite)
ENABLE_DATABASE=1  # Set to 1 to enable database features

# Feast feature store
# SECURITY: Default is now "0" (disabled) - set to "1" only if you use Feast
# Options: 0 (disabled), 1 (enabled)
ENABLE_FEATURE_STORE=0

# Hardware Security Module (HSM) support
# SECURITY: Default is now "0" (disabled) - set to "1" only if you have an HSM
# Options: 0 (disabled), 1 (enabled)
ENABLE_HSM=0

# Libvirt virtualization
# SECURITY: Default is now "0" (disabled) - set to "1" only if needed
# Options: 0 (disabled), 1 (enabled)
ENABLE_LIBVIRT=0

# =============================================================================
# Feature Flags - Observability
# =============================================================================
# Observability features (enabled by default in production)

# Audit logging (automatically enabled in production)
ENABLE_AUDIT_LOGGING=0  # Force enable in development with 1

# Audit crypto mode - controls cryptographic signing of audit logs
# NEW DEFAULT: "software" (secure by default, changed from "disabled" on 2026-02-03)
# Options:
#   - "software": Full cryptographic signing with software keys (RECOMMENDED for production)
#   - "hsm": Hardware Security Module (highest security)
#   - "dev": Use development mode with dummy keys (requires AUDIT_LOG_DEV_MODE=true)
#   - "disabled": NO SECURITY - blocked in production, for initial setup only
# 
# ⚠️  SECURITY: Production environments validate and block "disabled" mode
# ⚠️  For production, use "software" with AUDIT_CRYPTO_SOFTWARE_KEY_MASTER_ENCRYPTION_KEY_B64
AUDIT_CRYPTO_MODE=software  # Default changed to "software" for security

# Audit crypto provider type (should match AUDIT_CRYPTO_MODE)
# Options: software, hsm, dummy (auto-selected based on AUDIT_CRYPTO_MODE)
AUDIT_CRYPTO_PROVIDER_TYPE=software

# Audit crypto secret for software key master (REQUIRED if AUDIT_CRYPTO_MODE=software)
# Generate with: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# ⚠️  CRITICAL: Store in secrets manager in production (AWS Secrets Manager, GCP, Vault)
# ⚠️  DO NOT commit to version control
# AUDIT_CRYPTO_SOFTWARE_KEY_MASTER_ENCRYPTION_KEY_B64=

# Allow audit crypto initialization to fail without crashing the application
# Set to 1 in dev/test environments where audit logging is optional
# Set to 0 in production once secrets are properly configured
AUDIT_CRYPTO_ALLOW_INIT_FAILURE=1  # Set to 0 in production with proper secrets

# Prometheus metrics (disabled only in test mode)
# Leave unset to auto-enable in production
# ENABLE_PROMETHEUS=1

# =============================================================================
# Performance Configuration
# =============================================================================
# Control startup performance and resource usage

# Parallel agent loading (RECOMMENDED)
# Reduces startup time from ~60s to ~8s
PARALLEL_AGENT_LOADING=1  # Set to 0 to disable (for debugging)

# Lazy loading of ML libraries
# Defers heavy imports (torch, transformers) until first use
LAZY_LOAD_ML=1  # Set to 0 to load all at startup

# Startup timeout for health checks (seconds)
STARTUP_TIMEOUT=90

# =============================================================================
# API Keys for LLM Providers (REQUIRED)
# =============================================================================
# IMPORTANT: Configure at least ONE LLM provider for agent functionality
# In production mode (PRODUCTION_MODE=1), startup will fail if no keys are set
# 
# GRACEFUL DEGRADATION: Missing optional LLM provider keys will log warnings
# instead of crashing. The system uses a plugin-based architecture that catches
# provider initialization failures and continues with available providers.
# Only the default provider (DEFAULT_LLM_PROVIDER) needs to be configured.

# xAI Grok (supports both XAI_API_KEY and GROK_API_KEY)
# Optional - system will work without it if another provider is configured
# XAI_API_KEY=your-xai-api-key-here
# GROK_API_KEY=your-grok-api-key-here
# GROK_MODEL=grok-beta

# OpenAI (RECOMMENDED as default provider)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
# Optional: Custom base URL (for Azure OpenAI, etc.)
# OPENAI_BASE_URL=https://your-azure-endpoint.openai.azure.com

# Google Gemini
# Optional - system will work without it if another provider is configured
# GOOGLE_API_KEY=your-google-api-key-here
# GEMINI_API_KEY=your-google-api-key-here  # Alternative variable name
# GOOGLE_MODEL=gemini-pro

# Anthropic Claude
# Optional - system will work without it if another provider is configured
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# CLAUDE_API_KEY=your-anthropic-api-key-here  # Alternative variable name
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama (local LLM)
# OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=codellama

# Default LLM Provider Configuration
DEFAULT_LLM_PROVIDER=openai  # Options: openai, grok, anthropic, google, ollama
LLM_TIMEOUT=300  # Timeout for LLM API requests in seconds
LLM_MAX_RETRIES=3  # Maximum number of retries for LLM API requests
LLM_TEMPERATURE=0.7  # Temperature for LLM generation (0.0-2.0)
ENABLE_ENSEMBLE_MODE=false  # Enable ensemble mode for multiple LLM calls
ENABLE_LLM_CACHING=true  # Enable caching of LLM responses

# Tokenizer configuration
# TOKENIZERS_PARALLELISM controls parallelism in Hugging Face tokenizers
# Setting to false prevents fork warnings when using multiprocessing
# This is automatically set to false in the code if not specified
# TOKENIZERS_PARALLELISM=false

# =============================================================================
# Database Configuration
# =============================================================================
# SQLite with aiosqlite (default for development)
# Note: SQLAlchemy async requires async drivers (aiosqlite for SQLite, asyncpg for PostgreSQL)
DB_PATH=sqlite+aiosqlite:///./dev.db

# PostgreSQL with asyncpg (for production)
# Note: Use postgresql+asyncpg:// for async SQLAlchemy support
# DB_PATH=postgresql+asyncpg://user:password@localhost:5432/codefactory

# Legacy DATABASE_URL format (automatically converted to async driver at runtime)
# DATABASE_URL=sqlite:///./dev.db
# DATABASE_URL=postgresql://user:password@localhost:5432/codefactory

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# Message Bus Configuration
# =============================================================================
MESSAGE_BUS_TYPE=redis  # Options: redis, kafka, memory

# =============================================================================
# Self-Fixing Engineer (SFE) Dispatch Configuration
# =============================================================================
# Manual job dispatch to SFE (triggered via UI button or API endpoint)
# Configure at least ONE dispatch method for manual SFE dispatch feature
# Priority: Kafka (primary) → HTTP Webhook (fallback)

# KAFKA Configuration (for SFE job dispatch)
# GRACEFUL DEGRADATION: Kafka is OPTIONAL. If unavailable, the system will:
#   1. Log a warning about Kafka connection failure
#   2. Continue with file-only audit logging
#   3. Use retry logic with exponential backoff (max 6 retries)
#   4. Fall back to local logging if Kafka remains unavailable
# Set KAFKA_ENABLED=false to skip Kafka initialization entirely

# Enable/disable Kafka integration
KAFKA_ENABLED=false  # Set to true to enable Kafka message bus (default: false)

# Kafka connection settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=job-completed  # Topic for job completion events sent to SFE
KAFKA_DLQ_TOPIC=audit-events-dlq  # Dead letter queue for failed messages
KAFKA_REQUIRED=false  # Require Kafka to be available (allows fallback when false)

# HTTP Webhook Configuration (for SFE job dispatch fallback)
# Configure this if Kafka is not available or as a fallback method
# SFE_WEBHOOK_URL=https://sfe.example.com/api/v1/jobs/completed
# SFE_WEBHOOK_TOKEN=your-bearer-token-here  # Optional: Bearer token for authentication

# Kafka Graceful Degradation
# Set to true to operate without Kafka (logs events instead)
# Useful for development or when Kafka is unavailable
KAFKA_DEV_DRY_RUN=false  # Set to true to disable actual Kafka sends

# Kafka Connection Settings (optional - only needed if KAFKA_ENABLED=true)
# KAFKA_CLIENT_ID=audit-plugin
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT  # Options: PLAINTEXT, SSL, SASL_PLAINTEXT, SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN  # Options: PLAIN, SCRAM-SHA-256, SCRAM-SHA-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Kafka Retry & Backoff Configuration
# These settings prevent retry storms when Kafka is unavailable
KAFKA_MAX_RETRIES=6  # Maximum retry attempts per message (default: 6)
KAFKA_BASE_BACKOFF_MS=100  # Initial backoff time in milliseconds
KAFKA_MAX_BACKOFF_MS=30000  # Maximum backoff time (30 seconds)
KAFKA_MAX_RETRY_TOTAL_MS=120000  # Total retry window (2 minutes)

# Kafka Performance Tuning
# KAFKA_ACKS=all  # Wait for all replicas (highest durability)
# KAFKA_ENABLE_IDEMPOTENCE=true
# KAFKA_LINGER_MS=25  # Batch messages for up to 25ms
# KAFKA_BATCH_BYTES=16384  # 16KB batch size
# KAFKA_MAX_IN_FLIGHT=5  # Max concurrent requests
# KAFKA_COMPRESSION_TYPE=snappy  # Options: none, gzip, snappy, lz4, zstd
# KAFKA_REQUEST_TIMEOUT_MS=30000

# Kafka Queue Settings
# KAFKA_QUEUE_MAXSIZE=5000  # Internal queue size
# KAFKA_QUEUE_DROP_POLICY=block  # Options: block, drop_oldest, drop_newest
# KAFKA_FLUSH_INTERVAL_MS=200  # Flush batch every 200ms
# KAFKA_BATCH_MAX=100  # Max messages per batch
# KAFKA_SEND_CONCURRENCY=8  # Parallel send operations

# =============================================================================
# Blockchain/Web3 Configuration (for immutable audit logging)
# =============================================================================
# HIGH: Configure Web3 provider for blockchain audit logging
# WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
# WEB3_PROVIDER_URL=http://localhost:8545  # For local Ganache/Hardhat
# Leave commented out to disable blockchain audit logging
# WEB3_PROVIDER_URL=

# =============================================================================
# Observability
# =============================================================================
# Prometheus
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
PROMETHEUS_PORT=9090  # Port for Prometheus metrics HTTP server (default: 9090)
METRICS_PORT=8001     # Port for application metrics endpoint (default: 8001)

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=code-factory
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Options: json, text
AUDIT_LOG_PATH=./audit_trail.log

# =============================================================================
# Security
# =============================================================================
# Secret key for encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# Audit Signing Key - REQUIRED for production (non-DEV_MODE)
# Generate with: openssl rand -hex 32
# This key is used to cryptographically sign audit log entries
# WARNING: Generate a new key for production! The value below is for development only.
AUDIT_SIGNING_KEY=f0d108bfbbf4f7d547420d934367d476f8b8ea2b19529dc3002bfb9b6e8fa5d8

# Runner Audit Signing Key ID - maps to audit_signing_key_id in RunnerConfig
# This identifies the key used for V0 audit crypto system
RUNNER_AUDIT_SIGNING_KEY_ID=default-audit-key-v1

# Agentic Audit HMAC Key - used by self-fixing engineer audit logging
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# WARNING: Generate a new key for production! The value below is for development only.
AGENTIC_AUDIT_HMAC_KEY=4T61G858MlQUhM0uh4J1Ks7s6TLtsAqnDPHV464bubM

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# =============================================================================
# CORS Configuration (P0 - Critical for Browser Clients)
# =============================================================================
# CRITICAL: In production, ALLOWED_ORIGINS MUST be set or browser requests will fail!
#
# How it works:
# - If ALLOWED_ORIGINS is set: Only those origins can make browser requests
# - If NOT set in production: ALL browser CORS requests are blocked (safe default)
# - If NOT set in development: Common localhost ports are allowed
#
# Both ALLOWED_ORIGINS and CORS_ORIGINS are supported (ALLOWED_ORIGINS takes precedence)
#
# Examples:
#   Development: ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
#   Production:  ALLOWED_ORIGINS=https://yourdomain.com,https://app.railway.app
#
# Note: Server-to-server/curl requests work without CORS configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000  # Alternative variable name
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# Worker Configuration (P3 - Performance)
# =============================================================================
# Number of worker processes for handling concurrent requests
# Default: 1 (single worker is fine for async FastAPI)
# Increase for CPU-bound workloads or high concurrency
# WEB_CONCURRENCY=1  # or 2, 4, etc.

# =============================================================================
# Self-Fixing Engineer Configuration
# =============================================================================
CREW_CONFIG_PATH=./self_fixing_engineer/agent_orchestration/crew_config.yaml
SANDBOXED_ENV=1
CHECKPOINT_BACKEND_TYPE=fs  # Options: fs, s3, fabric

# =============================================================================
# Generator Agent Configuration
# =============================================================================
# Enable/disable specific generator agents
ENABLE_CODEGEN_AGENT=true
ENABLE_TESTGEN_AGENT=true
ENABLE_DEPLOY_AGENT=true
ENABLE_DOCGEN_AGENT=true
ENABLE_CRITIQUE_AGENT=true
ENABLE_CLARIFIER=true

# Agent behavior settings
STRICT_MODE=false  # Fail fast if agents cannot be imported (production mode)
USE_LLM_CLARIFIER=true  # Use LLM-based clarifier instead of rule-based
UPLOAD_DIR=./uploads  # Directory for storing uploaded files and generated code
# Strict mode for agent loading - when enabled, server will fail to start if any
# required agents cannot be loaded. Useful for production validation.
GENERATOR_STRICT_MODE=0  # Set to 1 to require all agents at startup

# Codegen agent strict mode - when enabled, codegen will fail fast if runner
# dependencies are not available instead of falling back to mock implementations
CODEGEN_STRICT_MODE=0  # Set to 1 to fail fast in production

# Testgen agent configuration
# CRITICAL: Increase LLM timeout for heavy test generation workloads
# Default timeout is 120s which may be insufficient for large files
TESTGEN_LLM_TIMEOUT=300  # Timeout in seconds for LLM calls (default: 300)

# Docker validation configuration
# GRACEFUL DEGRADATION: Docker is OPTIONAL for deployment validation
# When false (default), Docker validation is skipped if Docker is not available
# When true, deployment validation will fail if Docker is not installed
# The system will:
#   1. Check for Docker binary using shutil.which("docker")
#   2. Skip Docker-based validation (like Dockerfile linting) if not found
#   3. Log a warning about Docker not being available
#   4. Continue with static Dockerfile validation (regex-based)
# This allows the platform to run in environments without Docker
DOCKER_REQUIRED=false  # Set to true to enforce Docker availability

# Skip Docker build validation in CI/production environments
# Set to true in Railway or other environments where Docker daemon is not available
SKIP_DOCKER_VALIDATION=false  # Set to true for Railway deployment

# =============================================================================
# Clarifier Configuration
# =============================================================================
# Configuration for the LLM-based requirements clarification module
# These settings control encryption, alerting, and data persistence

# Encryption key for sensitive data (history, context)
# Production: Use AWS KMS, HashiCorp Vault, or similar secret management
# Development: Can be left empty (encryption features will be limited)
CLARIFIER_KMS_KEY_ID=

# Alert endpoint for operational notifications
# Production: Set to your monitoring/alerting system endpoint
# Development: Can be left empty (alerts will be logged only)
CLARIFIER_ALERT_ENDPOINT=

# Persistent storage path for audit trail and history
# Production: Use persistent volume mount (e.g., /var/lib/clarifier/history.json)
# Development: Uses /tmp/clarifier_history.json by default
CLARIFIER_HISTORY_FILE=./data/clarifier_history.json

# Persistent storage path for context database
# Production: Use persistent volume mount (e.g., /var/lib/clarifier/context.db)
# Development: Uses /tmp/clarifier_context.db by default
CLARIFIER_CONTEXT_DB_PATH=./data/clarifier_context.db

# Optional clarifier settings
CLARIFIER_LLM_PROVIDER=auto  # Options: auto, openai, anthropic, grok, google, gemini, ollama, local
CLARIFIER_INTERACTION_MODE=cli  # Options: cli (more modes coming soon)
CLARIFIER_TARGET_LANGUAGE=en  # Language for user prompts
CLARIFIER_HISTORY_COMPRESSION=false  # Enable compression for history files

# =============================================================================
# Cloud Storage (Optional)
# =============================================================================
# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=codefactory-checkpoints

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GCS_BUCKET_NAME=codefactory-checkpoints

# =============================================================================
# Blockchain/DLT Configuration (Optional)
# =============================================================================
# Hyperledger Fabric
FABRIC_NETWORK_URL=fabric://localhost
FABRIC_CHANNEL_NAME=codefactory-channel
FABRIC_CHAINCODE_NAME=checkpoint

# Ethereum/EVM
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your-project-id
ETHEREUM_PRIVATE_KEY=your-private-key-here
CONTRACT_ADDRESS=0x...

# =============================================================================
# Neo4j Knowledge Graph Configuration (Optional)
# =============================================================================
# Neo4j connection settings
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
# NEO4J_PASSWORD is required in production (ENV != "dev")
# In development mode (ENV="dev" or not set), the system will work without Neo4j
NEO4J_PASSWORD=your-secure-password-here

# Use AWS Secrets Manager for Neo4j password (recommended for production)
# USE_SECRETS_MANAGER=true
# NEO4J_SECRET_ID=neo4j/password
# NEO4J_SECRET_JSON_KEY=password

# =============================================================================
# SIEM Integration (Optional)
# =============================================================================
# AWS CloudWatch
CLOUDWATCH_LOG_GROUP=/aws/codefactory
CLOUDWATCH_LOG_STREAM=main

# Azure Sentinel
AZURE_WORKSPACE_ID=your-workspace-id
AZURE_PRIMARY_KEY=your-primary-key

# Splunk
SPLUNK_HOST=splunk.example.com
SPLUNK_PORT=8088
SPLUNK_TOKEN=your-splunk-token

# =============================================================================
# Notification Configuration (Optional)
# =============================================================================
# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-email-password
AUDIT_ALERT_EMAIL=alerts@example.com

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# =============================================================================
# Development Tools
# =============================================================================
# Hot reload for development
WATCHDOG_ENABLED=true

# API Documentation
DOCS_URL=/docs
REDOC_URL=/redoc

# =============================================================================
# Performance Tuning
# =============================================================================
# Worker configuration
WORKER_COUNT=4
MAX_CONCURRENT_TASKS=10

# Timeout settings (in seconds)
REQUEST_TIMEOUT=300
TASK_TIMEOUT=600

# Cache settings
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Health check settings
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_SELF_HEALING=true
ENABLE_AUTO_DEPLOY=false
ENABLE_BLOCKCHAIN_LOGGING=false
ENABLE_TELEMETRY=true
ENABLE_METRICS=true
EXPERIMENTAL_FEATURES_ENABLED=false  # Enable experimental encryption and anonymization features

# Testing and Production Modes
TESTING=0  # Set to 1 to enable testing mode (skips Presidio/spaCy/torch initialization)
PRODUCTION_MODE=0  # Set to 1 for production mode
TEST_GENERATION_OFFLINE_MODE=false  # Set to true to run test generation in offline mode

# =============================================================================
# Error Tracking and Monitoring
# =============================================================================
# Sentry for error tracking and monitoring
# MEDIUM: Enable Sentry by setting SENTRY_DSN environment variable
# Get your DSN from: https://sentry.io/settings/[your-org]/projects/[your-project]/keys/
# SENTRY_DSN=https://[key]@[organization].ingest.sentry.io/[project-id]
# SENTRY_ENVIRONMENT=production  # Options: production, staging, development
# SENTRY_TRACES_SAMPLE_RATE=0.1  # Sample 10% of traces for performance monitoring
# SENTRY_PROFILES_SAMPLE_RATE=0.1  # Sample 10% of profiling data

# =============================================================================
# Feature Store (Optional)
# =============================================================================
# Feast feature store configuration
# FEAST_REPO_PATH=/path/to/feast/repo
# FEAST_ONLINE_STORE_TYPE=redis
# FEAST_OFFLINE_STORE_TYPE=file

# =============================================================================
# Compliance
# =============================================================================
COMPLIANCE_MODE=NIST  # Options: NIST, ISO27001, HIPAA, GDPR, SOC2
ENABLE_PII_REDACTION=true
ENABLE_AUDIT_LOGGING=true
