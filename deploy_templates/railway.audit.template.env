# Railway Deployment Configuration Template for Audit Logging
# =============================================================================
# This template provides Railway-specific configuration for the audit logging
# system. Copy this file and customize for your deployment.
#
# Usage:
#   1. Copy this file: cp railway.audit.template.env railway.audit.env
#   2. Update all REPLACE_WITH_* placeholders
#   3. Add variables to Railway dashboard or railway.toml
#   4. Validate: make audit-config-validate-env
# =============================================================================

# =============================================================================
# Core Audit Log Configuration
# =============================================================================

# Backend Configuration
# Railway S3-compatible storage (recommended)
AUDIT_LOG_BACKEND_TYPE=s3
AUDIT_LOG_BACKEND_PARAMS={"bucket":"${RAILWAY_PROJECT_NAME}-audit-logs","region":"us-east-1","prefix":"${RAILWAY_ENVIRONMENT_NAME}/"}

# Or use Railway Volume (file-based)
# AUDIT_LOG_BACKEND_TYPE=file
# AUDIT_LOG_BACKEND_PARAMS={"log_file":"/data/audit.log"}

# Encryption key (CRITICAL - use Railway secrets)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AUDIT_LOG_ENCRYPTION_KEY=${AUDIT_ENCRYPTION_KEY}

# Immutability (MUST be true for production)
AUDIT_LOG_IMMUTABLE=true

# Service Ports (Railway auto-assigns but you can specify)
AUDIT_LOG_METRICS_PORT=8002
AUDIT_LOG_API_PORT=8003
AUDIT_LOG_GRPC_PORT=50051

# =============================================================================
# Cryptographic Provider Configuration
# =============================================================================

# Provider type (software for Railway, HSM requires dedicated infrastructure)
AUDIT_CRYPTO_PROVIDER_TYPE=software

# Signing algorithm
AUDIT_CRYPTO_DEFAULT_ALGO=ed25519

# Key rotation interval (7 days = 604800 seconds)
AUDIT_CRYPTO_KEY_ROTATION_INTERVAL_SECONDS=604800

# Software key directory (use Railway volume)
AUDIT_CRYPTO_SOFTWARE_KEY_DIR=/data/audit_keys

# AWS KMS for key encryption (if using AWS)
# AUDIT_CRYPTO_KMS_KEY_ID=alias/audit-log-key-prod
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
# AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}

# =============================================================================
# Performance and Optimization
# =============================================================================

# Compression (recommended for Railway to reduce storage costs)
AUDIT_COMPRESSION_ALGO=zstd
AUDIT_COMPRESSION_LEVEL=3

# Batch processing (optimized for Railway's network)
AUDIT_BATCH_FLUSH_INTERVAL=5
AUDIT_BATCH_MAX_SIZE=500

# Retry configuration
AUDIT_RETRY_MAX_ATTEMPTS=5
AUDIT_RETRY_BACKOFF_FACTOR=1.0

# Health checks
AUDIT_HEALTH_CHECK_INTERVAL=60

# =============================================================================
# Security Configuration
# =============================================================================

# Tamper detection (REQUIRED for compliance)
AUDIT_TAMPER_DETECTION_ENABLED=true

# Development mode (MUST be false in production)
AUDIT_LOG_DEV_MODE=false
AUDIT_CRYPTO_ALLOW_INIT_FAILURE=false
AUDIT_CRYPTO_ALLOW_DUMMY_PROVIDER=false
AUDIT_DEV_MODE_ALLOW_INSECURE_SECRETS=false

# Force real crypto provider
AUDIT_CRYPTO_FORCE_REAL_PROVIDER=true

# Crypto mode (MUST be 'full' in production)
AUDIT_CRYPTO_MODE=full

# =============================================================================
# Secret Management
# =============================================================================

# Use Railway secrets or environment variables
SECRET_MANAGER=env
USE_ENV_SECRETS=true

# Or use AWS Secrets Manager
# SECRET_MANAGER=aws
# USE_AWS_SECRETS=true
# AWS_REGION=us-east-1

# =============================================================================
# Observability
# =============================================================================

# OpenTelemetry tracing
TRACING_ENABLED=true
TRACING_SAMPLE_RATE=0.1

# Railway provides logging, but you can configure OTEL endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector:4317

# =============================================================================
# Compliance Configuration
# =============================================================================

# Compliance mode (set according to your requirements)
COMPLIANCE_MODE=soc2

# Data retention (adjust based on compliance requirements)
# SOC2: 365 days minimum
# HIPAA: 2555 days (7 years) minimum
DATA_RETENTION_DAYS=365

# =============================================================================
# Railway-Specific Settings
# =============================================================================

# Railway environment detection
RAILWAY_ENVIRONMENT_NAME=${RAILWAY_ENVIRONMENT}
RAILWAY_PROJECT_NAME=${RAILWAY_PROJECT_NAME}

# Railway provides these automatically
# RAILWAY_PUBLIC_DOMAIN=${RAILWAY_PUBLIC_DOMAIN}
# RAILWAY_PRIVATE_DOMAIN=${RAILWAY_PRIVATE_DOMAIN}

# =============================================================================
# Alerting Configuration
# =============================================================================

# Alert endpoint (Slack webhook, PagerDuty, etc.)
# Configure in Railway secrets
ALERT_ENDPOINT=${AUDIT_ALERT_WEBHOOK_URL}
ALERT_MIN_SEVERITY=error
ALERT_RETRY_ATTEMPTS=5

# =============================================================================
# Application Context
# =============================================================================

# Set production mode
PRODUCTION_MODE=1
APP_ENV=production
PYTHON_ENV=production

# Disable test/development modes
TEST_GENERATION_OFFLINE_MODE=false
CODEGEN_STRICT_MODE=1
GENERATOR_STRICT_MODE=1

# =============================================================================
# Railway Deployment Checklist
# =============================================================================
# 
# Before deploying to Railway:
# 
# [ ] Generate and store AUDIT_LOG_ENCRYPTION_KEY in Railway secrets
# [ ] Configure S3-compatible storage or Railway volume for audit logs
# [ ] Set up AWS credentials if using KMS or S3
# [ ] Configure alert webhook URL in Railway secrets
# [ ] Set RAILWAY_ENVIRONMENT (staging/production)
# [ ] Review and adjust batch sizes based on traffic
# [ ] Configure appropriate data retention period
# [ ] Set up monitoring and alerting
# [ ] Validate configuration: make audit-config-validate-env
# [ ] Test in staging environment first
# [ ] Document emergency procedures
# [ ] Set up backup and disaster recovery
# [ ] Configure log rotation if using file backend
# 
# Railway CLI Commands:
# 
# # Link project
# railway link
# 
# # Set secrets
# railway variables set AUDIT_LOG_ENCRYPTION_KEY="<generated-key>"
# railway variables set AUDIT_ALERT_WEBHOOK_URL="<webhook-url>"
# 
# # Deploy
# railway up
# 
# # View logs
# railway logs
# 
# # Check status
# railway status
# 
