{
  "app_settings": {
    "redis_url": "${REDIS_URL:-redis://localhost:6379}",
    "db_path": "${DB_PATH:-sqlite:///./arbiter_knowledge.db}",
    "encryption_key": "${ENCRYPTION_KEY}",
    "log_file": "${LOG_FILE:-arbiter_log.txt}",
    "audit_log_path": "${AUDIT_LOG_PATH:-app/ai_assistant/knowledge/audit_log.json}"
  },
  "security": {
    "valid_domain_pattern": "^[a-zA-Z0-9_-]+$"
  },
  "ml_models": {
    "model_path": "models/relevance_classifier.pth",
    "low_confidence_threshold": 0.2,
    "similarity_threshold": 0.8
  },
  "llm": {
    "api_url": "https://api.openai.com/v1/completions",
    "api_key": "${OPENAI_API_KEY}",
    "model_name": "${LLM_MODEL_NAME:-gpt-4o-mini}",
    "temperature": "${LLM_TEMPERATURE:-0.7}",
    "max_tokens": "${LLM_MAX_TOKENS:-500}",
    "top_p": "${LLM_TOP_P:-1.0}",
    "frequency_penalty": "${LLM_FREQUENCY_PENALTY:-0.0}",
    "presence_penalty": "${LLM_PRESENCE_PENALTY:-0.0}",
    "system_prompt": "${LLM_SYSTEM_PROMPT:-}"
  },
  "third_party_integrations": {
    "jira": {
      "api_url": "${JIRA_API_URL:-https://jira.example.com}",
      "api_token": "${JIRA_API_TOKEN}",
      "project_key": "${JIRA_PROJECT_KEY:-}",
      "issue_type": "${JIRA_ISSUE_TYPE:-}"
    },
    "web3": {
      "provider_url": "${WEB3_PROVIDER_URL}"
    },
    "zero_mq": {
      "bug_address": "${ZMQ_BUG_ADDRESS:-tcp://localhost:5555}"
    },
    "captcha_solver": {
      "api_key": "${CAPTCHA_API_KEY}"
    },
    "slack": {
      "webhook_url": "${SLACK_WEBHOOK_URL}",
      "channel": "${SLACK_CHANNEL}"
    },
    "email": {
      "enabled": "${EMAIL_ENABLED:-false}",
      "sender": "${EMAIL_SENDER}",
      "recipients": "${EMAIL_RECIPIENTS}",
      "smtp_server": "${EMAIL_SMTP_SERVER}",
      "smtp_port": "${EMAIL_SMTP_PORT:-587}",
      "smtp_username": "${EMAIL_SMTP_USERNAME}",
      "smtp_password": "${EMAIL_SMTP_PASSWORD}",
      "use_tls": "${EMAIL_USE_TLS:-true}",
      "timeout_seconds": "${EMAIL_TIMEOUT_SECONDS:-10.0}"
    },
    "pagerduty": {
      "enabled": "${PAGERDUTY_ENABLED:-false}",
      "routing_key": "${PAGERDUTY_ROUTING_KEY}",
      "api_timeout_seconds": "${PAGERDUTY_API_TIMEOUT_SECONDS:-10.0}"
    }
  },
  "knowledge_management": {
    "refresh_interval_seconds": 86400,
    "max_learn_retries": 3
  },
  "data_explorer": {
    "enabled": true,
    "max_depth": 3,
    "max_pages": 100,
    "rate_limit_per_second": 5,
    "allowed_domains": [
      "*.yahoo.com",
      "sec.gov",
      "reuters.com"
    ],
    "user_agent": "SelfFixingEngineerBot/1.0 (support@unexpectedinnovations.com)",
    "proxy": null,
    "headless_browser": true,
    "screenshot_enabled": true,
    "compliance_flags": {
      "gdpr": true,
      "ccpa": true,
      "finra_rule_2210": true
    }
  },
  "audit": {
    "buffer_size": "${AUDIT_BUFFER_SIZE:-100}",
    "flush_interval": "${AUDIT_FLUSH_INTERVAL:-5.0}",
    "blockchain_enabled": "${AUDIT_BLOCKCHAIN_ENABLED:-false}"
  }
}