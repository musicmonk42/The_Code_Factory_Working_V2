    "last_updated": {{ _now | tojson }},
    "spec_format": {{ spec_format | tojson }},
    "source_spec_hash": {{ _spec_canonical | tojson }},
    "source_spec_excerpt": {{ (spec | redact_secrets) | truncate(1024, True) | tojson }},
