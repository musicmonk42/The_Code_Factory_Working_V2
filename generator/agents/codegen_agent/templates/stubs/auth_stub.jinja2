def hash_password(plain: str) -> str:
    if _PASSLIB_AVAILABLE:
        return _pwd_context.hash(plain)
    salt = os.urandom(16).hex()
    digest = hashlib.sha256(f"{salt}{plain}".encode()).hexdigest()
    return f"{salt}${digest}"


def verify_password(plain: str, hashed: str) -> bool:
    if _PASSLIB_AVAILABLE:
        return _pwd_context.verify(plain, hashed)
    parts = hashed.split("$", 1)
    if len(parts) != 2:
        return False
    salt, digest = parts
    expected = hashlib.sha256(f"{salt}{plain}".encode()).hexdigest()
    return hmac.compare_digest(expected, digest)


def create_access_token(data: dict[str, Any], expires_in_minutes: int | None = None) -> str:
    payload = data.copy()
    expire = int(time.time()) + (expires_in_minutes or ACCESS_TOKEN_EXPIRE_MINUTES) * 60
    payload["exp"] = expire
    if _JWT_BACKEND == "jose":
        return jwt.encode(payload, SECRET_KEY, algorithm=ALGORITHM)
    raw = json.dumps(payload, sort_keys=True, default=str).encode()
    sig = hmac.new(SECRET_KEY.encode(), raw, hashlib.sha256).hexdigest()
    header = base64.urlsafe_b64encode(json.dumps({"alg": "HS256"}).encode()).decode().rstrip("=")
    body = base64.urlsafe_b64encode(json.dumps(payload).encode()).decode().rstrip("=")
    return f"{header}.{body}.{sig}"


def decode_access_token(token: str) -> dict[str, Any]:
    if _JWT_BACKEND == "jose":
        try:
            return jwt.decode(token, SECRET_KEY, algorithms=[ALGORITHM])
        except JWTError as exc:
            raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail="Could not validate credentials",
                headers={"WWW-Authenticate": "Bearer"},
            ) from exc
    parts = token.split(".")
    if len(parts) != 3:
        raise HTTPException(status_code=status.HTTP_401_UNAUTHORIZED, detail="Invalid token format")
    payload = json.loads(base64.urlsafe_b64decode(parts[1] + "=="))
    if payload.get("exp", 0) < int(time.time()):
        raise HTTPException(status_code=status.HTTP_401_UNAUTHORIZED, detail="Token expired")
    return payload


async def get_current_user(token: str = Depends(oauth2_scheme)) -> dict[str, Any]:
    payload = decode_access_token(token)
    sub = payload.get("sub")
    if sub is None:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Could not validate credentials",
            headers={"WWW-Authenticate": "Bearer"},
        )
    return {"sub": sub, **payload}

