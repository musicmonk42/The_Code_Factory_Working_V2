from __future__ import annotations

import os
from datetime import datetime, timedelta, timezone
from typing import Any, Optional
from uuid import UUID

from fastapi import APIRouter, Depends, HTTPException, status
from fastapi.security import OAuth2PasswordBearer, OAuth2PasswordRequestForm
from sqlalchemy.ext.asyncio import AsyncSession

try:
    from jose import JWTError, jwt as _jose_jwt
    _JWT_BACKEND = "jose"
except ImportError:
    _jose_jwt = None  # type: ignore[assignment]
    _JWT_BACKEND = "pyjwt"
    try:
        import jwt as _pyjwt  # PyJWT fallback
    except ImportError:
        _pyjwt = None  # type: ignore[assignment]

try:
    from passlib.context import CryptContext
    _pwd_context = CryptContext(schemes=["bcrypt"], deprecated="auto")
    _PASSLIB_AVAILABLE = True
except ImportError:
    import hashlib
    import hmac as _hmac_mod
    _PASSLIB_AVAILABLE = False

SECRET_KEY: str = os.environ.get("SECRET_KEY", "change-me-in-production")
ALGORITHM: str = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES: int = int(os.environ.get("ACCESS_TOKEN_EXPIRE_MINUTES", "30"))
REFRESH_TOKEN_EXPIRE_DAYS: int = int(os.environ.get("REFRESH_TOKEN_EXPIRE_DAYS", "7"))

{% if router_prefix is defined %}
router = APIRouter(prefix="{{ router_prefix }}", tags=["auth"])
{% else %}
router = APIRouter(prefix="/auth", tags=["auth"])
{% endif %}

{% if token_url is defined %}
oauth2_scheme = OAuth2PasswordBearer(tokenUrl="{{ token_url }}")
{% else %}
oauth2_scheme = OAuth2PasswordBearer(tokenUrl="/auth/token")
{% endif %}


def hash_password(plain: str) -> str:
    """Hash a plaintext password using bcrypt (passlib) or SHA-256 fallback."""
    if _PASSLIB_AVAILABLE:
        return _pwd_context.hash(plain)
    salt = os.urandom(16).hex()
    digest = hashlib.sha256(f"{salt}{plain}".encode()).hexdigest()
    return f"{salt}${digest}"


def verify_password(plain: str, hashed: str) -> bool:
    """Verify a plaintext password against its stored hash."""
    if _PASSLIB_AVAILABLE:
        return _pwd_context.verify(plain, hashed)
    parts = hashed.split("$", 1)
    if len(parts) != 2:
        return False
    salt, digest = parts
    expected = hashlib.sha256(f"{salt}{plain}".encode()).hexdigest()
    return _hmac_mod.compare_digest(expected, digest)


def create_access_token(data: dict[str, Any], expires_delta: Optional[timedelta] = None) -> str:
    """Create a signed JWT access token."""
    payload = data.copy()
    expire = datetime.now(timezone.utc) + (
        expires_delta or timedelta(minutes=ACCESS_TOKEN_EXPIRE_MINUTES)
    )
    payload["exp"] = expire
    payload["type"] = "access"
    if _JWT_BACKEND == "jose" and _jose_jwt is not None:
        return _jose_jwt.encode(payload, SECRET_KEY, algorithm=ALGORITHM)
    if _pyjwt is not None:
        return _pyjwt.encode(payload, SECRET_KEY, algorithm=ALGORITHM)
    raise RuntimeError("No JWT library available. Install python-jose or PyJWT.")


def create_refresh_token(data: dict[str, Any]) -> str:
    """Create a signed JWT refresh token with longer expiry."""
    return create_access_token(
        {**data, "type": "refresh"},
        expires_delta=timedelta(days=REFRESH_TOKEN_EXPIRE_DAYS),
    )


def decode_token(token: str) -> dict[str, Any]:
    """Decode and validate a JWT token, raising HTTP 401 on failure."""
    credentials_exception = HTTPException(
        status_code=status.HTTP_401_UNAUTHORIZED,
        detail="Could not validate credentials",
        headers={"WWW-Authenticate": "Bearer"},
    )
    try:
        if _JWT_BACKEND == "jose" and _jose_jwt is not None:
            payload = _jose_jwt.decode(token, SECRET_KEY, algorithms=[ALGORITHM])
        elif _pyjwt is not None:
            payload = _pyjwt.decode(token, SECRET_KEY, algorithms=[ALGORITHM])
        else:
            raise credentials_exception
    except Exception:
        raise credentials_exception
    if payload.get("sub") is None:
        raise credentials_exception
    return payload


async def get_current_user(token: str = Depends(oauth2_scheme)) -> dict[str, Any]:
    """FastAPI dependency: decode token and return the current user payload."""
    return decode_token(token)


@router.post("/token", summary="Obtain access and refresh tokens")
async def login(form_data: OAuth2PasswordRequestForm = Depends()) -> dict:
    """Authenticate user credentials and issue JWT tokens.

    Callers must provide a valid username/password via OAuth2 password grant.
    Replace the placeholder user lookup below with a real database query.
    """
    from app.database import get_db  # noqa: PLC0415
    # IMPORTANT: Replace this stub user lookup with a real database query:
    #   user = await user_service.get_by_username(db, form_data.username)
    #   if user is None or not verify_password(form_data.password, user.hashed_password):
    #       raise HTTPException(status_code=401, detail="Incorrect username or password")
    if not form_data.username or not form_data.password:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Incorrect username or password",
            headers={"WWW-Authenticate": "Bearer"},
        )
    token_data = {"sub": form_data.username}
    access_token = create_access_token(token_data)
    refresh_token = create_refresh_token(token_data)
    return {
        "access_token": access_token,
        "refresh_token": refresh_token,
        "token_type": "bearer",
        "expires_in": ACCESS_TOKEN_EXPIRE_MINUTES * 60,
    }


@router.post("/logout", summary="Invalidate the current session token")
async def logout(current_user: dict = Depends(get_current_user)) -> dict:
    """Logout the current user.

    For stateless JWT, logout is handled client-side by discarding the token.
    For stateful sessions, add the token JTI to a deny-list in Redis/DB here.
    """
    return {"detail": "Successfully logged out", "sub": current_user.get("sub")}


@router.post("/refresh", summary="Refresh an access token using a refresh token")
async def refresh_token(token: str = Depends(oauth2_scheme)) -> dict:
    """Issue a new access token given a valid refresh token."""
    payload = decode_token(token)
    if payload.get("type") != "refresh":
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Invalid token type — provide a refresh token",
            headers={"WWW-Authenticate": "Bearer"},
        )
    new_access = create_access_token({"sub": payload["sub"]})
    return {
        "access_token": new_access,
        "token_type": "bearer",
        "expires_in": ACCESS_TOKEN_EXPIRE_MINUTES * 60,
    }
