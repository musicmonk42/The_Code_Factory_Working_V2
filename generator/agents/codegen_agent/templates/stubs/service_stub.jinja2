from __future__ import annotations

from typing import Any, Sequence

from sqlalchemy import select, insert, update, delete
from sqlalchemy.ext.asyncio import AsyncSession
{% if class_names %}
# Import models from the application models package.
# Adjust the import path to match your project layout (e.g. from app.models import ...).
try:
{% for cls in class_names %}
    from app.models import {{ cls }}
{% endfor %}
except ImportError:
{% for cls in class_names %}
    {{ cls }}: Any = None  # type: ignore[assignment,misc]
{% endfor %}
{% endif %}


{% for cls in class_names %}
async def get_{{ cls | lower }}(session: AsyncSession, record_id: int) -> {{ cls }} | None:
    result = await session.execute(select({{ cls }}).where({{ cls }}.id == record_id))
    return result.scalar_one_or_none()


async def list_{{ cls | lower }}s(
    session: AsyncSession,
    *,
    limit: int = 100,
    offset: int = 0,
) -> Sequence[{{ cls }}]:
    result = await session.execute(
        select({{ cls }}).order_by({{ cls }}.id).limit(limit).offset(offset)
    )
    return result.scalars().all()


async def create_{{ cls | lower }}(session: AsyncSession, data: dict) -> {{ cls }}:
    result = await session.execute(
        insert({{ cls }}).values(**data).returning({{ cls }})
    )
    await session.commit()
    return result.scalar_one()


async def update_{{ cls | lower }}(
    session: AsyncSession, record_id: int, data: dict
) -> {{ cls }} | None:
    result = await session.execute(
        update({{ cls }})
        .where({{ cls }}.id == record_id)
        .values(**data)
        .returning({{ cls }})
    )
    await session.commit()
    return result.scalar_one_or_none()


async def delete_{{ cls | lower }}(session: AsyncSession, record_id: int) -> bool:
    result = await session.execute(
        delete({{ cls }}).where({{ cls }}.id == record_id)
    )
    await session.commit()
    return result.rowcount > 0

{% endfor %}
{% set _primary = class_names[0] | lower if class_names else "" %}
{% set _crud_names = [
    "get_" + _primary,
    "list_" + _primary + "s",
    "create_" + _primary,
    "update_" + _primary,
    "delete_" + _primary,
] %}
{% for fn in function_names %}
{% if fn not in _crud_names %}
{% if class_names %}
async def {{ fn }}(session: AsyncSession, **kwargs) -> dict:
    result = await session.execute(select({{ class_names[0] }}))
    rows = result.scalars().all()
    return {"items": [{c.name: getattr(r, c.name) for c in r.__table__.columns} for r in rows], "count": len(rows)}
{% else %}
async def {{ fn }}(session: AsyncSession, **kwargs) -> dict:
    return {"function": "{{ fn }}", "kwargs": kwargs}
{% endif %}

{% endif %}
{% endfor %}
