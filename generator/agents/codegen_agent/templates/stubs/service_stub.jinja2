{#
service_stub.jinja2 — SQLAlchemy Async Service Layer Stub Template
SPDX-License-Identifier: Proprietary
Copyright (c) 2025 Novatrax Labs

Generates a production-ready async service layer stub using SQLAlchemy 2.x
async sessions.  For each class name, produces get/list/create/update/delete
CRUD coroutines via the service_method macro in service_template.jinja2.
Additional function names receive generic session-aware stubs.

Template Variables:
- class_names: List of ORM model class names to generate CRUD functions for
- function_names: List of additional async service function names to generate
#}
{% from 'service_template.jinja2' import service_method %}
from __future__ import annotations

from typing import Any, List, Sequence
from uuid import UUID

from fastapi import HTTPException
from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession
{% if class_names %}
# Import models from the application models package.
# Adjust the import path to match your project layout (e.g. from app.models import ...).
try:
{% for cls in class_names %}
    from app.models import {{ cls }}
{% endfor %}
except ImportError:
{% for cls in class_names %}
    {{ cls }}: Any = None  # type: ignore[assignment,misc]
{% endfor %}
{% endif %}


{% for cls in class_names %}
{{ service_method('get_' + cls|lower, cls, 'get') }}

{{ service_method('list_' + cls|lower + 's', cls, 'list') }}

{{ service_method('create_' + cls|lower, cls, 'create', 'dict') }}

{{ service_method('update_' + cls|lower, cls, 'update', 'dict') }}

{{ service_method('delete_' + cls|lower, cls, 'delete') }}

{% endfor %}
{% set _primary = class_names[0] | lower if class_names else "" %}
{% set _crud_names = [
    "get_" + _primary,
    "list_" + _primary + "s",
    "create_" + _primary,
    "update_" + _primary,
    "delete_" + _primary,
] %}
{% for fn in function_names %}
{% if fn not in _crud_names %}
{% if class_names %}
async def {{ fn }}(db: AsyncSession, **kwargs) -> dict:
    result = await db.execute(select({{ class_names[0] }}))
    rows = result.scalars().all()
    return {"items": [{c.name: getattr(r, c.name) for c in r.__table__.columns} for r in rows], "count": len(rows)}
{% else %}
async def {{ fn }}(db: AsyncSession, **kwargs) -> dict:
    return {"function": "{{ fn }}", "kwargs": kwargs}
{% endif %}

{% endif %}
{% endfor %}
