# Agent Loading Configuration
# ===========================
# These environment variables control the behavior of the agent loading and retry mechanisms
# to handle race conditions during startup.

# Agent Wait Timeout (seconds)
# Maximum time to wait for agents to load before failing a pipeline execution
# Default: 90 seconds (matches typical agent loading time of 5-10 seconds with safety margin)
# Recommended: 60-120 seconds depending on infrastructure performance
AGENT_WAIT_TIMEOUT=90

# Agent Wait Check Interval (seconds)
# How frequently to check if agents have finished loading
# Default: 2 seconds (balances responsiveness with system overhead)
# Recommended: 1-5 seconds
AGENT_WAIT_INTERVAL=2

# Agent Retry Attempts
# Number of retry attempts after initial request when agents are not ready
# Default: 3 retries (total 4 attempts: initial + 3 retries)
# Recommended: 2-5 retries
AGENT_RETRY_ATTEMPTS=3

# Agent Retry Base Delay (seconds)
# Base delay for exponential backoff between retry attempts
# Default: 5 seconds (with 3 retries: 5s, 10s, 20s using 2^n multiplier)
# Recommended: 3-10 seconds
AGENT_RETRY_BASE_DELAY=5

# Agent Retry Maximum Delay (seconds)
# Maximum delay cap for exponential backoff
# Prevents extremely long waits on later retry attempts
# Default: 30 seconds
# Recommended: 20-60 seconds
AGENT_RETRY_MAX_DELAY=30

# Configuration Examples
# ======================

# Development Environment (faster feedback, shorter timeouts)
# AGENT_WAIT_TIMEOUT=30
# AGENT_WAIT_INTERVAL=1
# AGENT_RETRY_ATTEMPTS=2
# AGENT_RETRY_BASE_DELAY=3
# AGENT_RETRY_MAX_DELAY=15

# Production Environment (more resilient, longer timeouts)
# AGENT_WAIT_TIMEOUT=120
# AGENT_WAIT_INTERVAL=2
# AGENT_RETRY_ATTEMPTS=5
# AGENT_RETRY_BASE_DELAY=5
# AGENT_RETRY_MAX_DELAY=45

# Testing Environment (minimal delays for fast test execution)
# AGENT_WAIT_TIMEOUT=10
# AGENT_WAIT_INTERVAL=1
# AGENT_RETRY_ATTEMPTS=1
# AGENT_RETRY_BASE_DELAY=1
# AGENT_RETRY_MAX_DELAY=5
