# Production Environment Configuration Template

# This file serves as a template for production environment variables.
# DO NOT use this file directly - copy it to a secure secrets manager.

# =============================================================================
# DEPLOYMENT INFORMATION
# =============================================================================
APP_ENV=production
DEBUG=false
VERSION=1.0.0
DEPLOYMENT_NAME=code-factory-prod
DEPLOYMENT_REGION=us-east-1

# =============================================================================
# SECRETS MANAGEMENT
# =============================================================================
# Choose one: env, aws, vault, gcp, azure
SECRETS_PROVIDER=aws

# AWS Secrets Manager Configuration
AWS_REGION=us-east-1
# Note: Use IAM roles in production, not access keys
# AWS_ACCESS_KEY_ID=<use-iam-role>
# AWS_SECRET_ACCESS_KEY=<use-iam-role>

# HashiCorp Vault Configuration
# VAULT_ADDR=https://vault.production.example.com:8200
# VAULT_TOKEN=<stored-in-kubernetes-secret>
# VAULT_NAMESPACE=production

# GCP Secret Manager Configuration
# GCP_PROJECT_ID=code-factory-prod
# GOOGLE_APPLICATION_CREDENTIALS=<use-workload-identity>

# Azure Key Vault Configuration
# AZURE_KEY_VAULT_URL=https://codefactory-prod.vault.azure.net/
# AZURE_TENANT_ID=<tenant-id>
# AZURE_CLIENT_ID=<use-managed-identity>

# =============================================================================
# API KEYS (Store in Secrets Manager)
# =============================================================================
# These should be stored in your secrets manager, not in this file
# Secret Names (for reference):
# - code-factory/prod/grok-api-key
# - code-factory/prod/openai-api-key
# - code-factory/prod/google-api-key
# - code-factory/prod/anthropic-api-key

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL for Production (recommended)
DATABASE_URL=postgresql://code_factory:STORE_IN_SECRETS_MANAGER@prod-db.example.com:5432/codefactory_prod
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_SSL_MODE=require

# Database credentials (store in secrets manager)
# Secret Name: code-factory/prod/database-password

# Read Replicas (optional)
# DATABASE_REPLICA_URLS=postgresql://readonly:PASSWORD@replica1.example.com:5432/codefactory_prod,postgresql://readonly:PASSWORD@replica2.example.com:5432/codefactory_prod

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://prod-redis.example.com:6379/0
REDIS_PASSWORD=STORE_IN_SECRETS_MANAGER
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5

# Redis Sentinel (for HA)
# REDIS_SENTINEL_HOSTS=sentinel1.example.com:26379,sentinel2.example.com:26379,sentinel3.example.com:26379
# REDIS_SENTINEL_MASTER=mymaster

# =============================================================================
# MESSAGE BUS CONFIGURATION
# =============================================================================
MESSAGE_BUS_TYPE=kafka  # kafka recommended for production

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka1.example.com:9093,kafka2.example.com:9093,kafka3.example.com:9093
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=code_factory_prod
KAFKA_SASL_PASSWORD=STORE_IN_SECRETS_MANAGER
KAFKA_SSL_CA_LOCATION=/etc/kafka/ca-cert.pem
KAFKA_CONSUMER_GROUP_ID=code-factory-prod
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_MAX_POLL_RECORDS=100

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Application Secrets (store in secrets manager)
# Secret Names:
# - code-factory/prod/secret-key
# - code-factory/prod/jwt-secret-key
# - code-factory/prod/encryption-key
# - code-factory/prod/audit-signing-private-key
# - code-factory/prod/audit-signing-key
# - code-factory/prod/agentic-audit-hmac-key

# =============================================================================
# AUDIT SIGNING KEYS - CRITICAL FOR PRODUCTION
# =============================================================================
# These keys are REQUIRED in production (non-DEV_MODE) for cryptographic signing
# of audit log entries. Without them, the application will fail at runtime.
#
# Generate keys with:
#   openssl rand -hex 32  (for AUDIT_SIGNING_KEY)
#   python -c "import secrets; print(secrets.token_urlsafe(32))"  (for AGENTIC_AUDIT_HMAC_KEY)

# Main audit signing key for log entry signatures
AUDIT_SIGNING_KEY=STORE_IN_SECRETS_MANAGER

# Key ID for the V0 audit crypto system
RUNNER_AUDIT_SIGNING_KEY_ID=prod-audit-key-v1

# HMAC key for agentic/self-fixing engineer audit logging
AGENTIC_AUDIT_HMAC_KEY=STORE_IN_SECRETS_MANAGER

# JWT Configuration
JWT_ALGORITHM=RS256  # Use RSA in production
JWT_EXPIRATION_MINUTES=15  # Short-lived tokens
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_ISSUER=code-factory.production.example.com
JWT_AUDIENCE=code-factory-api

# Encryption
ENCRYPTION_ALGORITHM=AES-256-GCM
KEY_DERIVATION_ITERATIONS=100000

# CORS Settings
CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_MAX_AGE=86400

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20
RATE_LIMIT_STORAGE=redis

# Security Headers
HSTS_MAX_AGE=31536000
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# =============================================================================
# TLS/SSL CONFIGURATION
# =============================================================================
# Certificate paths (mounted as Kubernetes secrets or from cert-manager)
TLS_ENABLED=true
TLS_CERT_PATH=/etc/ssl/certs/tls.crt
TLS_KEY_PATH=/etc/ssl/private/tls.key
TLS_CA_BUNDLE_PATH=/etc/ssl/certs/ca-bundle.crt
TLS_MIN_VERSION=1.2
TLS_CIPHERS=ECDHE-RSA-AES256-GCM-SHA384:ECDHE-RSA-AES128-GCM-SHA256

# =============================================================================
# OBSERVABILITY - LOGGING
# =============================================================================
LOG_LEVEL=INFO  # INFO for production
LOG_FORMAT=json
LOG_OUTPUT=stdout
AUDIT_LOG_PATH=/var/log/code-factory/audit.log
ERROR_LOG_PATH=/var/log/code-factory/error.log

# Structured Logging
LOG_INCLUDE_TIMESTAMP=true
LOG_INCLUDE_CALLER=true
LOG_INCLUDE_STACK_TRACE=true
LOG_SANITIZE_SENSITIVE=true

# Log Aggregation (ELK/Splunk/CloudWatch)
LOG_AGGREGATION_ENABLED=true
LOG_AGGREGATION_TYPE=cloudwatch  # Options: elk, splunk, cloudwatch, datadog

# CloudWatch
CLOUDWATCH_LOG_GROUP=/aws/codefactory/production
CLOUDWATCH_LOG_STREAM=app-logs
CLOUDWATCH_REGION=us-east-1

# Splunk
# SPLUNK_HOST=splunk.example.com
# SPLUNK_PORT=8088
# SPLUNK_TOKEN=STORE_IN_SECRETS_MANAGER
# SPLUNK_INDEX=codefactory-prod

# =============================================================================
# OBSERVABILITY - METRICS
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=8001
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Metric Collection
METRICS_COLLECT_INTERVAL=15
METRICS_INCLUDE_SYSTEM=true
METRICS_INCLUDE_PROCESS=true
METRICS_INCLUDE_GC=true

# =============================================================================
# OBSERVABILITY - TRACING
# =============================================================================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=code-factory-prod
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1  # 10% sampling in production

# Trace Headers
OTEL_PROPAGATORS=tracecontext,baggage
OTEL_RESOURCE_ATTRIBUTES=service.name=code-factory,service.version=1.0.0,deployment.environment=production

# =============================================================================
# OBSERVABILITY - ALERTS
# =============================================================================
ALERTS_ENABLED=true

# Alert Channels
ALERT_EMAIL=ops-team@example.com,oncall@example.com
ALERT_SLACK_WEBHOOK=STORE_IN_SECRETS_MANAGER
ALERT_PAGERDUTY_KEY=STORE_IN_SECRETS_MANAGER

# Alert Thresholds
ALERT_ERROR_RATE_THRESHOLD=0.05  # 5%
ALERT_LATENCY_P95_THRESHOLD=500  # milliseconds
ALERT_LATENCY_P99_THRESHOLD=1000  # milliseconds
ALERT_CPU_THRESHOLD=80  # percentage
ALERT_MEMORY_THRESHOLD=85  # percentage
ALERT_DISK_THRESHOLD=90  # percentage

# =============================================================================
# SIEM INTEGRATION
# =============================================================================
SIEM_ENABLED=true
SIEM_TYPE=sentinel  # Options: splunk, sentinel, qradar

# Azure Sentinel
AZURE_WORKSPACE_ID=STORE_IN_SECRETS_MANAGER
AZURE_PRIMARY_KEY=STORE_IN_SECRETS_MANAGER

# =============================================================================
# SELF-FIXING ENGINEER CONFIGURATION
# =============================================================================
CREW_CONFIG_PATH=/app/config/crew_config.yaml
SANDBOXED_ENV=1
CHECKPOINT_BACKEND_TYPE=s3

# S3 Checkpoint Storage
S3_BUCKET_NAME=codefactory-prod-checkpoints
S3_BUCKET_REGION=us-east-1
S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
S3_USE_SSL=true
S3_VERIFY_SSL=true

# =============================================================================
# BLOCKCHAIN/DLT CONFIGURATION (Optional)
# =============================================================================
BLOCKCHAIN_ENABLED=false

# Hyperledger Fabric
# FABRIC_NETWORK_URL=fabric://fabric.example.com
# FABRIC_CHANNEL_NAME=codefactory-prod
# FABRIC_CHAINCODE_NAME=checkpoint
# FABRIC_ORG_MSP=CodeFactoryMSP
# FABRIC_PEER_ENDPOINT=peer0.example.com:7051
# FABRIC_ORDERER_ENDPOINT=orderer.example.com:7050

# Ethereum/EVM
# ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/PROJECT_ID
# ETHEREUM_PRIVATE_KEY=STORE_IN_SECRETS_MANAGER
# CONTRACT_ADDRESS=0x...
# ETHEREUM_CHAIN_ID=1
# ETHEREUM_GAS_PRICE=auto

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Worker Configuration
WORKER_COUNT=8  # Number of worker processes
WORKER_MAX_REQUESTS=1000  # Restart worker after N requests (prevent memory leaks)
WORKER_MAX_REQUESTS_JITTER=100
WORKER_TIMEOUT=300  # seconds

# Concurrent Tasks
MAX_CONCURRENT_TASKS=50
TASK_QUEUE_MAX_SIZE=1000

# Timeout Settings
REQUEST_TIMEOUT=300  # seconds
TASK_TIMEOUT=600
LONG_RUNNING_TASK_TIMEOUT=3600

# Connection Pooling
HTTP_POOL_CONNECTIONS=20
HTTP_POOL_MAXSIZE=100
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_FACTOR=0.3

# Cache Settings
CACHE_ENABLED=true
CACHE_BACKEND=redis
CACHE_TTL=3600  # seconds
CACHE_MAX_SIZE=10000
CACHE_KEY_PREFIX=codefactory:prod:

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_SELF_HEALING=true
ENABLE_AUTO_DEPLOY=false  # Manual approval required in production
ENABLE_BLOCKCHAIN_LOGGING=false
ENABLE_TELEMETRY=true
ENABLE_METRICS=true
ENABLE_PROFILING=false  # Only enable for debugging
ENABLE_DEBUG_ENDPOINTS=false  # Never enable in production

# Feature Rollout (0.0 to 1.0)
FEATURE_AI_OPTIMIZATION=1.0
FEATURE_NEW_UI=0.5  # 50% rollout
FEATURE_EXPERIMENTAL=0.0  # Disabled

# =============================================================================
# COMPLIANCE
# =============================================================================
COMPLIANCE_MODE=NIST,ISO27001,SOC2
ENABLE_PII_REDACTION=true
ENABLE_AUDIT_LOGGING=true
AUDIT_RETENTION_DAYS=2555  # 7 years
DATA_RESIDENCY=US  # US, EU, APAC
GDPR_COMPLIANCE=true

# Audit Configuration
AUDIT_LOG_ROTATION=daily
AUDIT_LOG_MAX_SIZE=100MB
AUDIT_LOG_BACKUP_COUNT=365
AUDIT_SIGN_LOGS=true
AUDIT_ENCRYPT_LOGS=true

# =============================================================================
# BACKUP AND DISASTER RECOVERY
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE=s3
BACKUP_S3_BUCKET=codefactory-prod-backups
BACKUP_S3_REGION=us-east-1
BACKUP_ENCRYPTION=AES256

# Point-in-Time Recovery
PITR_ENABLED=true
PITR_RETENTION_DAYS=7

# Disaster Recovery
DR_REGION=us-west-2
DR_SYNC_ENABLED=true
DR_RTO_HOURS=4  # Recovery Time Objective
DR_RPO_HOURS=1  # Recovery Point Objective

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================
# Email (SMTP)
SMTP_ENABLED=true
SMTP_SERVER=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=STORE_IN_SECRETS_MANAGER
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Code Factory Production

# Slack
SLACK_ENABLED=true
SLACK_WEBHOOK_URL=STORE_IN_SECRETS_MANAGER
SLACK_CHANNEL=#code-factory-prod
SLACK_USERNAME=Code Factory Bot

# PagerDuty
PAGERDUTY_ENABLED=true
PAGERDUTY_API_KEY=STORE_IN_SECRETS_MANAGER
PAGERDUTY_SERVICE_KEY=STORE_IN_SECRETS_MANAGER

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30  # seconds
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_THRESHOLD=3  # failures before unhealthy

# Dependencies to check
HEALTH_CHECK_DATABASE=true
HEALTH_CHECK_REDIS=true
HEALTH_CHECK_KAFKA=true
HEALTH_CHECK_S3=true
HEALTH_CHECK_EXTERNAL_APIS=false  # Can be slow

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# Rolling Update Strategy
DEPLOYMENT_STRATEGY=RollingUpdate
DEPLOYMENT_MAX_SURGE=25%
DEPLOYMENT_MAX_UNAVAILABLE=25%
DEPLOYMENT_MIN_READY_SECONDS=10

# Liveness Probe
LIVENESS_PROBE_PATH=/health/live
LIVENESS_PROBE_INITIAL_DELAY=30
LIVENESS_PROBE_PERIOD=10
LIVENESS_PROBE_TIMEOUT=5
LIVENESS_PROBE_FAILURE_THRESHOLD=3

# Readiness Probe
READINESS_PROBE_PATH=/health/ready
READINESS_PROBE_INITIAL_DELAY=10
READINESS_PROBE_PERIOD=5
READINESS_PROBE_TIMEOUT=3
READINESS_PROBE_FAILURE_THRESHOLD=3

# =============================================================================
# RESOURCE LIMITS (Kubernetes)
# =============================================================================
# These are reference values for K8s manifests

# Container Resources
# resources:
#   requests:
#     memory: "2Gi"
#     cpu: "1000m"
#   limits:
#     memory: "4Gi"
#     cpu: "2000m"

# Horizontal Pod Autoscaling
# HPA_MIN_REPLICAS=3
# HPA_MAX_REPLICAS=10
# HPA_TARGET_CPU=70
# HPA_TARGET_MEMORY=80

# =============================================================================
# LOAD BALANCER CONFIGURATION
# =============================================================================
LB_ALGORITHM=round_robin  # round_robin, least_conn, ip_hash
LB_SESSION_AFFINITY=ClientIP
LB_SESSION_AFFINITY_TIMEOUT=3600
LB_HEALTH_CHECK_PATH=/health
LB_HEALTH_CHECK_INTERVAL=10
LB_HEALTH_CHECK_TIMEOUT=5
LB_HEALTH_CHECK_HEALTHY_THRESHOLD=2
LB_HEALTH_CHECK_UNHEALTHY_THRESHOLD=3

# =============================================================================
# CDN CONFIGURATION (Optional)
# =============================================================================
# CDN_ENABLED=true
# CDN_PROVIDER=cloudflare  # cloudflare, cloudfront, akamai
# CDN_DOMAIN=cdn.example.com
# CDN_CACHE_TTL=3600
# CDN_PURGE_ON_DEPLOY=true

# =============================================================================
# API DOCUMENTATION
# =============================================================================
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json
DOCS_ENABLED=true  # Can disable in production if not needed publicly

# =============================================================================
# ENVIRONMENT-SPECIFIC NOTES
# =============================================================================
# 1. Store all secrets in AWS Secrets Manager or equivalent
# 2. Use IAM roles instead of access keys where possible
# 3. Enable encryption at rest for all data stores
# 4. Enable encryption in transit (TLS) for all connections
# 5. Implement network segmentation (private subnets for databases)
# 6. Enable WAF for public-facing APIs
# 7. Implement DDoS protection
# 8. Regular security audits and penetration testing
# 9. Automated backup verification
# 10. Disaster recovery drills quarterly

# =============================================================================
# DEPLOYMENT CHECKLIST
# =============================================================================
# Before deploying to production, ensure:
# [ ] All secrets stored in secrets manager
# [ ] SSL/TLS certificates configured
# [ ] Database backups enabled
# [ ] Monitoring and alerting configured
# [ ] Log aggregation working
# [ ] Health checks passing
# [ ] Load testing completed
# [ ] Security scan passed
# [ ] Disaster recovery plan documented
# [ ] Incident response plan ready
# [ ] On-call rotation established
# [ ] Runbooks created
# [ ] Change management process followed
