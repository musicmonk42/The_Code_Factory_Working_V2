# Production Environment Configuration Template
# For The Code Factory Platform - Critical Production Fixes
#
# ⚠️  SECURITY WARNING: DO NOT use this file directly in production!
# ⚠️  Copy to .env.production and replace ALL placeholder/example values
# ⚠️  Generate unique cryptographic keys per deployment
# ⚠️  Store actual secrets in environment variables or a secrets manager
#
# Usage Instructions:
#   1. cp .env.production.template .env.production
#   2. Generate secure keys using the commands provided below
#   3. Replace all placeholder values with your generated keys
#   4. Add .env.production to .gitignore to prevent commits
#   5. In production, use environment variables or secrets manager instead of .env files

# =============================================================================
# CRITICAL: Production Mode Configuration
# =============================================================================
PRODUCTION_MODE=1
APP_ENV=production

# Disable test/stub mode
TEST_GENERATION_OFFLINE_MODE=false
CODEGEN_STRICT_MODE=1
GENERATOR_STRICT_MODE=1

# =============================================================================
# CORS Configuration (CRITICAL for Browser Access)
# =============================================================================
# Comma-separated list of allowed origins for CORS
# ⚠️  CRITICAL: Set this to your actual frontend domain(s) in production
# 
# Security Note:
#   - If deployed on Railway, the server will auto-detect Railway *.railway.app URLs
#   - If not on Railway and ALLOWED_ORIGINS is not set, browser requests will be BLOCKED
#   - This secure-by-default behavior prevents CSRF attacks and unauthorized access
#   - Always specify exact domains in production for security
#
# Examples:
#   Single domain: ALLOWED_ORIGINS=https://myapp.example.com
#   Multiple domains: ALLOWED_ORIGINS=https://myapp.example.com,https://app.mycompany.com
#   Railway deployment: ALLOWED_ORIGINS=https://your-app.railway.app,https://your-frontend.railway.app
#   Development: ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# 
# ⚠️  DO NOT use wildcard (*) in production as it creates security vulnerabilities
# ⚠️  Replace the placeholder below with your actual domain(s) before deploying
ALLOWED_ORIGINS=https://your-frontend.example.com
# CORS_ORIGINS is an alternative variable name (ALLOWED_ORIGINS takes precedence)
# CORS_ORIGINS=https://your-frontend.example.com
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# Output Directory for File Access
# =============================================================================
OUTPUT_DIR=/app/output

# =============================================================================
# Docker Configuration
# =============================================================================
# Docker validation can be skipped in CI/production environments where Docker daemon is not available
# Set to true to skip Docker build validation (useful for Railway deployment)
SKIP_DOCKER_VALIDATION=true
DOCKER_REQUIRED=false

# =============================================================================
# Kafka Configuration
# =============================================================================
# Kafka is optional for production - system will use in-memory queue as fallback
# Set to true to enable Kafka message bus (default: false)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=job-completed
KAFKA_REQUIRED=false

# =============================================================================
# Audit Configuration
# =============================================================================
# Enable audit logging
ENABLE_AUDIT_LOGGING=1

# Audit crypto mode - SECURITY CRITICAL
# NEW DEFAULT: "software" (secure by default, changed from "disabled" on 2026-02-03)
# Options: 
#   - software (RECOMMENDED): Cryptographic signatures with software keys
#   - hsm: Hardware Security Module (highest security)
#   - dev: Development mode with dummy keys (requires AUDIT_LOG_DEV_MODE=true)
#   - disabled: NO SECURITY (blocked in production, for initial setup only)
# 
# ⚠️  CRITICAL: Production environments MUST use "software" or "hsm"
# Setting "disabled" in production will BLOCK STARTUP for security
AUDIT_CRYPTO_MODE=software

# Audit crypto provider type (matches AUDIT_CRYPTO_MODE)
AUDIT_CRYPTO_PROVIDER_TYPE=software

# Master encryption key for audit crypto (REQUIRED for software mode)
# Generate with: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# ⚠️  CRITICAL: Store this in a secrets manager (AWS Secrets Manager, GCP, Vault)
# ⚠️  DO NOT commit this to version control
# ⚠️  Rotate this key regularly per your security policy
# The placeholder below is a valid base64 string but INSECURE - REPLACE IMMEDIATELY
AUDIT_CRYPTO_SOFTWARE_KEY_MASTER_ENCRYPTION_KEY_B64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Allow startup without crypto secrets (SET TO 0 for strict production)
# Set to 0 once secrets are properly configured
AUDIT_CRYPTO_ALLOW_INIT_FAILURE=1

# Audit signing key 
# ⚠️  GENERATE A NEW KEY: openssl rand -hex 32
# ⚠️  DO NOT use this example value in production!
AUDIT_SIGNING_KEY=REPLACE_WITH_YOUR_GENERATED_KEY_HERE

# Agentic audit HMAC key
# ⚠️  GENERATE A NEW KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️  DO NOT use this example value in production!
AGENTIC_AUDIT_HMAC_KEY=REPLACE_WITH_YOUR_GENERATED_KEY_HERE

# =============================================================================
# Audit Log System Configuration
# =============================================================================
# For comprehensive configuration options, see docs/AUDIT_CONFIGURATION.md
# For YAML-based configuration, see generator/audit_config.production.yaml

# --- Core Audit Log Settings ---

# Audit log encryption key (Fernet format - base64 encoded)
# ⚠️  CRITICAL: Generate a secure key for production
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# AUDIT_LOG_ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# Audit log backend type
# Options: file, sqlite, s3, gcs, azure, http, kafka, splunk
# Production: Use s3, gcs, or azure for durability
AUDIT_LOG_BACKEND_TYPE=file

# Backend parameters (JSON format)
# File: {"log_file": "/path/to/audit.log"}
# S3: {"bucket": "company-audit-logs", "prefix": "prod/", "region": "us-east-1"}
# AUDIT_LOG_BACKEND_PARAMS={"log_file": "/var/audit/audit.log"}

# Enable immutable logging (prevent deletion/modification)
# Production: MUST be true
AUDIT_LOG_IMMUTABLE=true

# --- Audit Crypto Provider Settings ---

# Crypto provider type
# Options: software (file-based keys), hsm (Hardware Security Module)
# Production: Use hsm for maximum security
AUDIT_CRYPTO_PROVIDER_TYPE=software

# Default signing algorithm
# Options: rsa, ecdsa, ed25519, hmac
# Recommended: ed25519 for best performance
AUDIT_CRYPTO_DEFAULT_ALGO=ed25519

# Key rotation interval (seconds)
# Minimum: 86400 (24 hours)
# Recommended: 604800 (7 days) for production
AUDIT_CRYPTO_KEY_ROTATION_INTERVAL_SECONDS=604800

# Software key directory (if using software provider)
# ⚠️  Set restrictive permissions: chmod 0700
AUDIT_CRYPTO_SOFTWARE_KEY_DIR=/var/audit/keys

# AWS KMS Key ID for master key encryption
# Format: alias/key-name or full ARN
AUDIT_CRYPTO_KMS_KEY_ID=alias/audit-log-key-prod

# --- Backend Performance Settings ---

# Compression algorithm
# Options: none, gzip, zstd
# Recommended: zstd for best compression and performance
AUDIT_COMPRESSION_ALGO=zstd

# Compression level (algorithm-dependent)
# zstd: 1-22 (3 recommended), gzip: 1-9 (6 recommended)
AUDIT_COMPRESSION_LEVEL=3

# Batch processing settings
# Flush interval: How often to write buffered logs (seconds)
AUDIT_BATCH_FLUSH_INTERVAL=5

# Maximum batch size before forced flush
AUDIT_BATCH_MAX_SIZE=500

# --- Fault Tolerance Settings ---

# Retry configuration for failed operations
AUDIT_RETRY_MAX_ATTEMPTS=5
AUDIT_RETRY_BACKOFF_FACTOR=1.0

# Health check interval (seconds)
AUDIT_HEALTH_CHECK_INTERVAL=60

# --- Security Settings ---

# Enable tamper detection with cryptographic chaining
# Production: MUST be true for compliance
AUDIT_TAMPER_DETECTION_ENABLED=true

# Development mode (NEVER enable in production)
# Allows ephemeral keys and relaxed security
AUDIT_LOG_DEV_MODE=false

# Allow dummy crypto provider (testing only)
AUDIT_CRYPTO_ALLOW_DUMMY_PROVIDER=false

# Allow insecure secrets (testing only)
AUDIT_DEV_MODE_ALLOW_INSECURE_SECRETS=false

# Force real crypto provider (override dev mode)
AUDIT_CRYPTO_FORCE_REAL_PROVIDER=true

# --- Service Ports ---

# Prometheus metrics port
AUDIT_LOG_METRICS_PORT=8002

# FastAPI REST API port
AUDIT_LOG_API_PORT=8003

# gRPC service port
AUDIT_LOG_GRPC_PORT=50051

# --- RBAC (Role-Based Access Control) ---

# Path to users and roles configuration file
# AUDIT_LOG_USERS_CONFIG=/etc/audit/users.yaml

# --- Secret Management ---

# Secret manager type
# Options: aws (AWS Secrets Manager), gcp (GCP Secret Manager), 
#          vault (HashiCorp Vault), env (environment variables), mock (testing only)
# Production: Use aws, gcp, or vault - NEVER mock
SECRET_MANAGER=env

# Enable specific secret manager
# USE_AWS_SECRETS=true
# USE_GCP_SECRETS=false
# USE_HASHICORP_VAULT=false
USE_ENV_SECRETS=true

# --- Additional Configuration ---

# For full configuration options, use YAML config files:
# - generator/audit_config.production.yaml (production defaults)
# - generator/audit_config.development.yaml (development defaults)
# - generator/audit_config.enhanced.yaml (all options documented)
#
# Validate configuration with:
# python generator/audit_log/validate_config.py
#
# See comprehensive documentation:
# docs/AUDIT_CONFIGURATION.md

# =============================================================================
# LLM Configuration
# =============================================================================
# Configure at least ONE LLM provider for basic functionality
# Additional providers are optional and will be gracefully disabled if not configured
# The system will display which providers are available vs missing at startup

# OpenAI (RECOMMENDED as default provider)
# OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo

# xAI Grok (supports both XAI_API_KEY and GROK_API_KEY)
# Optional - system will work without it if another provider is configured
# XAI_API_KEY=your-xai-api-key-here
# GROK_API_KEY=your-grok-api-key-here
GROK_MODEL=grok-beta

# Google Gemini (supports both GOOGLE_API_KEY and GEMINI_API_KEY)
# Optional - system will work without it if another provider is configured
# GOOGLE_API_KEY=your-google-api-key-here
# GEMINI_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-pro

# Anthropic Claude (supports both ANTHROPIC_API_KEY and CLAUDE_API_KEY)
# Optional - system will work without it if another provider is configured
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# CLAUDE_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Default LLM Provider Configuration
DEFAULT_LLM_PROVIDER=openai
LLM_TIMEOUT=300

# =============================================================================
# Agent Configuration
# =============================================================================
ENABLE_CODEGEN_AGENT=true
ENABLE_TESTGEN_AGENT=true
ENABLE_DEPLOY_AGENT=true
ENABLE_DOCGEN_AGENT=true
ENABLE_CRITIQUE_AGENT=true

# Strict mode - fail fast if agents cannot load
STRICT_MODE=true

# =============================================================================
# Database Configuration
# =============================================================================
# Use PostgreSQL for production, SQLite for development
DB_PATH=sqlite+aiosqlite:///./production.db
# DB_PATH=postgresql+asyncpg://user:password@localhost:5432/codefactory

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# Security - Cryptographic Keys
# =============================================================================
# ⚠️  CRITICAL: Generate unique keys for each deployment
# ⚠️  Store in environment variables or secrets manager in production
# ⚠️  NEVER commit actual production keys to version control

# Application secret key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_YOUR_GENERATED_SECRET_KEY

# JWT secret key (for authentication tokens)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_YOUR_GENERATED_JWT_SECRET

# =============================================================================
# Performance
# =============================================================================
PARALLEL_AGENT_LOADING=1
LAZY_LOAD_ML=1
WORKER_COUNT=4
MAX_CONCURRENT_TASKS=10

# =============================================================================
# Observability
# =============================================================================
LOG_LEVEL=INFO  # Case-insensitive, normalized to uppercase internally
LOG_FORMAT=json
ENABLE_TELEMETRY=true
ENABLE_METRICS=true

# SFE Checkpoint Manager Logging
# Uses container-friendly defaults: ./logs/checkpoint/audit.log and ./logs/checkpoint/dlq.jsonl
# Override only if custom paths required
# CHECKPOINT_AUDIT_LOG_PATH=/app/logs/checkpoint/audit.log
# CHECKPOINT_DLQ_PATH=/app/logs/checkpoint/dlq.jsonl

# Prometheus
PROMETHEUS_PORT=9090
METRICS_PORT=8001

# =============================================================================
# Upload and Output Directories
# =============================================================================
UPLOAD_DIR=/app/uploads
