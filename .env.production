# Production Environment Configuration
# For The Code Factory Platform - Critical Production Fixes

# =============================================================================
# CRITICAL: Production Mode Configuration
# =============================================================================
PRODUCTION_MODE=1
APP_ENV=production

# Disable test/stub mode
TEST_GENERATION_OFFLINE_MODE=false
CODEGEN_STRICT_MODE=1
GENERATOR_STRICT_MODE=1

# =============================================================================
# Output Directory for File Access
# =============================================================================
OUTPUT_DIR=/app/output

# =============================================================================
# Audit Configuration
# =============================================================================
# Enable audit logging
ENABLE_AUDIT_LOGGING=1

# Audit crypto mode - set to full if you have secrets configured, otherwise disabled
# Options: full (requires secrets), dev (dummy keys), disabled (no crypto)
AUDIT_CRYPTO_MODE=disabled

# Allow startup without crypto secrets
AUDIT_CRYPTO_ALLOW_INIT_FAILURE=1

# Audit signing key (generate with: openssl rand -hex 32)
AUDIT_SIGNING_KEY=f0d108bfbbf4f7d547420d934367d476f8b8ea2b19529dc3002bfb9b6e8fa5d8

# Agentic audit HMAC key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
AGENTIC_AUDIT_HMAC_KEY=7f8a9b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a

# =============================================================================
# LLM Configuration
# =============================================================================
# Configure at least ONE LLM provider
# OPENAI_API_KEY=your-key-here
# XAI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here
DEFAULT_LLM_PROVIDER=openai
LLM_TIMEOUT=300

# =============================================================================
# Agent Configuration
# =============================================================================
ENABLE_CODEGEN_AGENT=true
ENABLE_TESTGEN_AGENT=true
ENABLE_DEPLOY_AGENT=true
ENABLE_DOCGEN_AGENT=true
ENABLE_CRITIQUE_AGENT=true

# Strict mode - fail fast if agents cannot load
STRICT_MODE=true

# =============================================================================
# Database Configuration
# =============================================================================
# Use PostgreSQL for production, SQLite for development
DB_PATH=sqlite+aiosqlite:///./production.db
# DB_PATH=postgresql+asyncpg://user:password@localhost:5432/codefactory

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# Security
# =============================================================================
# Generate new keys for production!
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-here

# =============================================================================
# Performance
# =============================================================================
PARALLEL_AGENT_LOADING=1
LAZY_LOAD_ML=1
WORKER_COUNT=4
MAX_CONCURRENT_TASKS=10

# =============================================================================
# Observability
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_TELEMETRY=true
ENABLE_METRICS=true

# Prometheus
PROMETHEUS_PORT=9090
METRICS_PORT=8001

# =============================================================================
# Upload and Output Directories
# =============================================================================
UPLOAD_DIR=/app/uploads
